---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="Home" description="Deterministic EverQuest deployment toolkit for Ubuntu 24.04 LTS via Wine and DXVK">
  <div class="not-prose mb-10">
    <h1 class="text-4xl font-bold mb-3" style="font-family: var(--font-heading); color: var(--color-gold-bright); letter-spacing: 0.01em;">
      norrath-native
    </h1>
    <p class="text-lg" style="color: var(--color-text); max-width: 60ch; line-height: 1.6;">
      Deterministic, idempotent deployment toolkit to run
      <strong style="color: var(--color-gold);">EverQuest</strong> natively on Ubuntu 24.04 LTS via Wine and DXVK.
    </p>
    <div class="flex gap-3 mt-5">
      <a href={`${base}guides/getting-started/`} class="inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-medium transition-colors" style="background: var(--color-gold); color: var(--color-bg); font-family: var(--font-heading); letter-spacing: 0.03em;">
        Get Started
      </a>
      <a href="https://github.com/williamzujkowski/norrath-native" class="inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-medium border transition-colors" style="border-color: var(--color-border); color: var(--color-text-muted);" target="_blank" rel="noopener">
        View on GitHub
      </a>
    </div>
  </div>

  <div class="not-prose grid gap-4 sm:grid-cols-2 mb-10">
    <a href={`${base}guides/getting-started/`} class="card-link block rounded-lg p-5" style={`background-color: var(--color-bg-card); border: 1px solid var(--color-border);`}>
      <h3 class="text-base font-semibold mb-1" style="font-family: var(--font-heading); color: var(--color-text-heading);">Getting Started</h3>
      <p class="text-sm" style="color: var(--color-text-muted);">Install prerequisites, deploy, and launch EQ in minutes.</p>
    </a>
    <a href={`${base}guides/multiboxing/`} class="card-link block rounded-lg p-5" style={`background-color: var(--color-bg-card); border: 1px solid var(--color-border);`}>
      <h3 class="text-base font-semibold mb-1" style="font-family: var(--font-heading); color: var(--color-text-heading);">Multiboxing</h3>
      <p class="text-sm" style="color: var(--color-text-muted);">Run multiple EQ instances with smart window tiling.</p>
    </a>
    <a href={`${base}guides/chat-setup/`} class="card-link block rounded-lg p-5" style={`background-color: var(--color-bg-card); border: 1px solid var(--color-border);`}>
      <h3 class="text-base font-semibold mb-1" style="font-family: var(--font-heading); color: var(--color-text-heading);">Chat Setup</h3>
      <p class="text-sm" style="color: var(--color-text-muted);">4-window raid chat with WCAG-compliant colors.</p>
    </a>
    <a href={`${base}reference/commands/`} class="card-link block rounded-lg p-5" style={`background-color: var(--color-bg-card); border: 1px solid var(--color-border);`}>
      <h3 class="text-base font-semibold mb-1" style="font-family: var(--font-heading); color: var(--color-text-heading);">Command Reference</h3>
      <p class="text-sm" style="color: var(--color-text-muted);">All make targets and CLI commands.</p>
    </a>
  </div>

  <h2>Features</h2>
  <ul>
    <li><strong>One-command deploy</strong> &mdash; Wine prefix, DXVK, EQ install, and config in a single <code>make deploy</code></li>
    <li><strong>30 health checks</strong> &mdash; <code>make doctor</code> validates your entire installation</li>
    <li><strong>Smart multiboxing</strong> &mdash; staggered launch, automatic window tiling, focus cycling</li>
    <li><strong>91 WCAG-compliant chat colors</strong> &mdash; designed for dark backgrounds and raid readability</li>
    <li><strong>107-channel chat routing</strong> &mdash; 4-window layout (Social, Combat, Spam, Alerts)</li>
    <li><strong>5 performance profiles</strong> &mdash; from high quality to minimal stick figures</li>
    <li><strong>47 managed INI settings</strong> &mdash; optimized for each profile, never touch your keybinds</li>
    <li><strong>EQLogParser integration</strong> &mdash; auto-install with separate Wine prefix</li>
  </ul>

  <h2>Requirements</h2>
  <ul>
    <li>Ubuntu 24.04 LTS (or compatible)</li>
    <li>Vulkan-capable GPU (AMD or NVIDIA)</li>
    <li>EverQuest account</li>
  </ul>
</BaseLayout>
