{
  "name": "norrath-native",
  "version": "1.0.0",
  "description": "Deterministic, idempotent deployment toolkit to run EverQuest natively on Ubuntu 24.04 LTS via Wine and DXVK",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc",
    "docs:check": "bash scripts/generate-docs.sh --check"
  },
  "devDependencies": {
    "@types/node": "22",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/williamzujkowski/norrath-native.git"
  },
  "homepage": "https://github.com/williamzujkowski/norrath-native#readme",
  "bugs": "https://github.com/williamzujkowski/norrath-native/issues",
  "author": "William Zujkowski",
  "keywords": [
    "everquest",
    "wine",
    "dxvk",
    "linux",
    "gaming",
    "multiboxing",
    "ubuntu"
  ],
  "license": "MIT"
}
