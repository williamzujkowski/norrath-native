{
  "name": "norrath-native",
  "version": "0.3.0",
  "description": "Deterministic, idempotent deployment toolkit to run EverQuest natively on Ubuntu 24.04 LTS via Wine and DXVK",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.{json,md,yaml,yml}'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' '*.{json,md,yaml,yml}'",
    "stats": "npx tsx scripts/generate-stats.ts",
    "stats:check": "npx tsx scripts/generate-stats.ts",
    "stats:fix": "npx tsx scripts/generate-stats.ts --fix",
    "docs:check": "bash scripts/generate-docs.sh --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.2.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.2",
    "tsx": "^4.21.0",
    "typedoc": "0.28.18",
    "typescript": "6.0.2",
    "vite": "7.3.2",
    "vitest": "4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/williamzujkowski/norrath-native.git"
  },
  "homepage": "https://github.com/williamzujkowski/norrath-native#readme",
  "bugs": "https://github.com/williamzujkowski/norrath-native/issues",
  "author": "William Zujkowski",
  "keywords": [
    "everquest",
    "wine",
    "dxvk",
    "linux",
    "gaming",
    "multiboxing",
    "ubuntu"
  ],
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "license": "MIT"
}
